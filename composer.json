{
  "name": "xpayr/xpayr-php",
  "description": "Official PHP SDK for the XPayr Merchant API.",
  "type": "library",
  "license": "MIT",
  "keywords": ["xpayr", "crypto-payments", "payment-gateway", "webhooks"],
  "homepage": "https://xpayr.com/developers",
  "support": {
    "issues": "https://github.com/xpayrcom/xpayr-php-sdk/issues",
    "docs": "https://xpayr.com/doc-api"
  },
  "repositories": [
    { "type": "vcs", "url": "https://github.com/xpayrcom/xpayr-php-sdk" }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "XPayr\\": "src/"
    }
  },
  "scripts": {
    "test": "php tests/run.php",
    "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 php -l"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
